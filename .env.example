LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional Gemini provider
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Set to false for deterministic offline intent classification.
USE_INTENT_LLM=true

# Set to false for deterministic offline triage matching.
# When true, LLM extracts triage slots and selects from knowledge-base candidate rules.
USE_TRIAGE_LLM=true

# Optional deterministic demo/evaluation time.
# Example values: 2026-05-11 or 2026-05-11T09:00:00
HOSPITAL_AGENT_NOW=
